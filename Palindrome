import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner s=new Scanner(System.in);
      int n=s.nextInt();
      int rev=0,b=n,a=0;
      while(b!=0)
      {
        a=b%10;
        rev=rev*10+a;
        b/=10;
        
      }
      if(rev==n){
        System.out.println("YES");
      }
      else{
        System.out.println("NO");
      }
  }
}
