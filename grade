import java.util.*;

public class Main {
    public static void main(String[] args) {{
        Scanner sc = new Scanner(System.in);
        int total = 0;
        for (int i = 0; i < 5; i++) {
            int mark = sc.nextInt();
            total += mark;
        }
        double average = total / 5.0;

        if (average >= 90) {
            System.out.println("A");
        } else if (average >= 80) {
            System.out.println("B");
        } else if (average >= 70) {
            System.out.println("C");
        } else if (average >= 50) {
            System.out.println("D");
        } else {
            System.out.println("F");
        }

        sc.close();
    }
}
;
  }
