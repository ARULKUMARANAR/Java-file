import java.util.*;

public class Main {
    public static void main(String[] args) {;
        Scanner sc = new Scanner(System.in);
        int day = sc.nextInt();
        String[] weekdays = {
            "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"
        };
        if (day >= 0 && day <= 6) {
            System.out.println(weekdays[day]);
        } else {
            System.out.println("Invalid input");
        }

    }
}
