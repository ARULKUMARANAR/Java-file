import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner s=new Scanner(System.in);
      int a=s.nextInt();
      if(a>0){
        System.out.println("POSITIVE");
      }
      else if(a<0){
        System.out.println("NEGATIVE");
      }
      else{
        System.out.println("ZERO");
      }
  }
}
