import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int number = sc.nextInt();

        switch (number % 2) {
            case 0:
                System.out.println("EVEN");
                break;
            case 1:
                System.out.println("ODD");
                break;
            default:
                System.out.println("Invalid input");
        }

        sc.close();
    }
}
